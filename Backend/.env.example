# Backend Server Configuration
PORT=4000
NODE_ENV=development

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Phase 4 Routing
INSTANCE_ID=backend-local
BACKEND_INSTANCES=backend-local
PUBLIC_GATEWAY_URL=http://localhost:4000

# Admin Authentication (IMPORTANT: Change this in production!)
ADMIN_PASSWORD=1234

# CORS Configuration
CORS_ORIGIN=*

# Production Example (uncomment and update for production deployment):
# PORT=4000
# NODE_ENV=production
# REDIS_HOST=redis.production.internal
# REDIS_PORT=6379
# REDIS_PASSWORD=your-secure-password-here
# ADMIN_PASSWORD=your-strong-admin-password-here
# INSTANCE_ID=backend-1
# BACKEND_INSTANCES=backend-1,backend-2
# PUBLIC_GATEWAY_URL=https://api.your-domain.com
# CORS_ORIGIN=https://your-domain.com
