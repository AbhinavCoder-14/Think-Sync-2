# Backend Server Configuration
PORT=4000
NODE_ENV=development

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Admin Authentication (IMPORTANT: Change this in production!)
ADMIN_PASSWORD=1234

# CORS Configuration
CORS_ORIGIN=*

# Production Example (uncomment and update for production deployment):
# PORT=4000
# NODE_ENV=production
# REDIS_HOST=redis.production.internal
# REDIS_PORT=6379
# REDIS_PASSWORD=your-secure-password-here
# ADMIN_PASSWORD=your-strong-admin-password-here
# CORS_ORIGIN=https://your-domain.com
